---
import BaseLayout from '@layouts/BaseLayout.astro';
import KrakenMini from '@components/brand/KrakenMini.astro';
import ArrowRight from '@components/icons/ArrowRight.astro';
import { getCollection } from 'astro:content';

const allCases = (await getCollection('caseStudies')).sort((a, b) =>
  b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const filters = ['Semua', 'Website', 'Google Ads', 'Meta Ads', 'Konsultasi'];
---
<BaseLayout
  title="Case Study"
  description="Kumpulan project yang kami kerjakan — angka yang sebenarnya, periode yang jelas, dan strategi di baliknya."
  active="case"
>
  <section style="padding-top:56px;padding-bottom:32px;background:var(--bg-warm);">
    <div class="container" style="text-align:center;position:relative;">
      <span class="eyebrow">Case Study</span>
      <h1 style="font-size:48px;margin-top:18px;margin-bottom:14px;">
        Hasil nyata, bukan <span style="color:var(--orange-500);">cherry-picked</span>.
      </h1>
      <p style="font-size:17px;color:var(--ink-500);max-width:620px;margin:0 auto;">
        Kumpulan project yang kami kerjakan — angka yang sebenarnya, periode yang jelas, dan strategi di baliknya.
      </p>
    </div>
  </section>

  <section style="padding-top:32px;">
    <div class="container">
      <div style="display:flex;justify-content:center;gap:8px;margin-bottom:32px;flex-wrap:wrap;">
        {filters.map((f, i) => (
          <button class={`filter-btn${i === 0 ? ' active' : ''}`} data-filter={f}>{f}</button>
        ))}
      </div>

      <div id="cases-grid" style="display:grid;grid-template-columns:repeat(3, 1fr);gap:20px;">
        {allCases.map(c => (
          <div class="card reveal case-card" data-tags={c.data.tags.join(',')}>
            <div style="height:160px;border-radius:12px;background:repeating-linear-gradient(135deg, var(--orange-100), var(--orange-100) 8px, var(--orange-50) 8px, var(--orange-50) 16px);display:flex;align-items:center;justify-content:center;border:1px dashed var(--orange-300);">
              <span style="font-family:monospace;font-size:12px;color:var(--orange-700);">{c.data.brand} — hero shot</span>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <span style="font-size:11px;color:var(--ink-500);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;">{c.data.industry ?? ''}</span>
              <span style="font-size:11px;color:var(--ink-500);">{c.data.period ?? ''}</span>
            </div>
            <h3 style="font-size:20px;">{c.data.brand}</h3>
            <div style="font-size:24px;font-weight:800;color:var(--orange-600);font-family:'Plus Jakarta Sans',sans-serif;">{c.data.metric}</div>
            <p style="font-size:14px;color:var(--ink-500);flex:1;">{c.data.desc}</p>
            <div style="display:flex;gap:6px;flex-wrap:wrap;">
              {c.data.tags.map(t => <span style="font-size:11px;padding:4px 10px;background:var(--orange-100);color:var(--orange-700);border-radius:999px;font-weight:600;">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="padding-bottom:24px;">
    <div class="container">
      <div class="cta-banner reveal">
        <div style="flex:1;">
          <h3>Mau jadi case study selanjutnya?</h3>
          <p style="margin-top:8px;opacity:0.95;font-size:15px;">Konsultasi gratis untuk lihat strategi yang cocok buat bisnis Anda.</p>
        </div>
        <a href="/kontak" class="btn btn-ghost">Mulai Sekarang <ArrowRight size={14} /></a>
        <div style="position:relative;"><KrakenMini size={110} /></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .filter-btn {
    padding: 8px 18px;
    border-radius: 999px;
    border: 1.5px solid var(--ink-100);
    background: white;
    color: var(--ink-700);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    font-family: inherit;
  }
  .filter-btn:hover { border-color: var(--orange-300); }
  .filter-btn.active { border-color: var(--orange-500); background: var(--orange-500); color: white; }
  .case-card { display: flex; flex-direction: column; gap: 14px; }
  .case-card[hidden] { display: none !important; }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.case-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'Semua';
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      cards.forEach(card => {
        const tags = (card.dataset.tags ?? '').split(',');
        const visible = filter === 'Semua' || tags.includes(filter);
        if (visible) card.removeAttribute('hidden');
        else card.setAttribute('hidden', '');
      });
    });
  });
</script>
