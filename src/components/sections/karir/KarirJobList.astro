---
import ArrowRight from '../../icons/ArrowRight.astro';
import WhatsApp from '../../icons/WhatsApp.astro';
import { getCollection } from 'astro:content';
import { waLink } from '@data/site';

const jobsCol = await getCollection('jobs');
const jobs = jobsCol.sort((a, b) => Number(a.id) - Number(b.id));
---
<section id="lowongan" style="background:var(--bg-warm);">
  <div class="container">
    <h2 class="section-title">Posisi yang Dibuka</h2>
    <p class="section-sub" style="margin-bottom:40px;">{jobs.length} posisi sedang aktif kami buka. Klik untuk detail dan apply.</p>
    <div style="display:flex;flex-direction:column;gap:14px;max-width:980px;margin:0 auto;">
      {jobs.map(j => (
        <div class="job-card reveal" data-job-card>
          <button class="job-card-head" type="button" aria-expanded="false" data-job-toggle>
            <div style="flex:1;text-align:left;">
              <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:8px;">
                <h3 style="font-size:20px;margin:0;">{j.data.title}</h3>
                <span class="job-pill job-pill-orange">{j.data.type}</span>
                <span class="job-pill">{j.data.location}</span>
                <span class="job-pill">{j.data.level}</span>
              </div>
              <p style="font-size:14.5px;color:var(--ink-500);margin:0;">{j.data.summary}</p>
            </div>
            <span class="job-card-toggle" aria-hidden="true">+</span>
          </button>
          <div class="job-card-body" hidden>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;">
              {j.data.tags.map(t => <span class="job-tag">{t}</span>)}
            </div>
            <h4 style="font-size:14px;font-weight:700;margin-bottom:10px;color:var(--ink-700);">Yang kami cari:</h4>
            <ul class="job-req-list">
              {j.data.requirements.map(r => <li>{r}</li>)}
            </ul>
            <div style="display:flex;gap:10px;margin-top:22px;flex-wrap:wrap;">
              <a href="#apply" class="btn btn-primary" data-apply-job={j.data.title}>
                Apply Posisi Ini <ArrowRight size={14} />
              </a>
              <a href={waLink(`Halo Tentaklik, saya tertarik dengan posisi ${j.data.title}`)} target="_blank" rel="noopener noreferrer" class="btn btn-wa">
                <WhatsApp size={16} /> Tanya via WhatsApp
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-job-toggle]').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('[data-job-card]') as HTMLElement | null;
      const body = card?.querySelector<HTMLElement>('.job-card-body');
      const toggle = btn.querySelector<HTMLElement>('.job-card-toggle');
      if (!card || !body || !toggle) return;
      const isOpen = card.classList.contains('open');
      if (isOpen) {
        card.classList.remove('open');
        body.hidden = true;
        toggle.textContent = '+';
        btn.setAttribute('aria-expanded', 'false');
      } else {
        card.classList.add('open');
        body.hidden = false;
        toggle.textContent = '−';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('[data-apply-job]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const role = link.dataset.applyJob;
      const apply = document.getElementById('apply');
      const select = document.getElementById('apply-role') as HTMLSelectElement | null;
      if (select && role) {
        select.value = role;
        // If role doesn't match any option, fall back to the last open-application option
        if (!select.value) {
          const openApp = select.querySelector<HTMLOptionElement>('option[value="Open Application"]');
          if (openApp) select.value = 'Open Application';
        }
      }
      apply?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
