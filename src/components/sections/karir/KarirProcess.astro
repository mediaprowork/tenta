---
const steps = [
  { n: '01', t: 'Submit Lamaran',        d: 'Isi form di bawah atau kirim CV via email/WhatsApp.' },
  { n: '02', t: 'Screening + Interview', d: 'HR call (30 menit) untuk kenalan dan culture fit.' },
  { n: '03', t: 'Technical / Case Study', d: 'Tugas kecil sesuai role. Real-world, bukan jebakan.' },
  { n: '04', t: 'Final & Offering',      d: 'Ngobrol langsung sama founder + diskusi offering.' },
];
---
<section id="proses">
  <div class="container">
    <h2 class="section-title">Proses Rekrutmen</h2>
    <p class="section-sub" style="margin-bottom:40px;">Cepat, transparan, dan respect waktu kamu.</p>
    <div style="display:grid;grid-template-columns:repeat(4, 1fr);gap:16px;max-width:1100px;margin:0 auto;">
      {steps.map(s => (
        <div class="process-step reveal">
          <div class="process-num">{s.n}</div>
          <h3 style="font-size:17px;margin-bottom:8px;">{s.t}</h3>
          <p style="font-size:13.5px;color:var(--ink-500);">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>
