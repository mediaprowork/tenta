---
const benefits = [
  { icon: '💰', title: 'Salary kompetitif + bonus', desc: 'Base + performance bonus berdasarkan output, bukan kehadiran.' },
  { icon: '🏝️', title: 'Hybrid / remote-friendly',  desc: 'Kerja dari mana saja. Yang penting hasil dan komunikasi rapi.' },
  { icon: '📚', title: 'Budget belajar',             desc: 'Course, sertifikasi, conference — kami support upgrade skill kamu.' },
  { icon: '🩺', title: 'BPJS & asuransi',            desc: 'BPJS Kesehatan + Ketenagakerjaan + asuransi tambahan setelah probation.' },
  { icon: '🧠', title: 'Tim kecil, dampak besar',    desc: 'Suara kamu didengar. Inisiatif kamu dieksekusi.' },
  { icon: '🦑', title: 'Kultur friendly',             desc: 'No politics, no ghosting. Tim yang saling support beneran.' },
];
---
<section>
  <div class="container">
    <h2 class="section-title">Kenapa Gabung Tentaklik?</h2>
    <p class="section-sub" style="margin-bottom:40px;">Bukan cuma tempat kerja — tempat tumbuh.</p>
    <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:20px;">
      {benefits.map(b => (
        <div class="card reveal">
          <div style="width:50px;height:50px;border-radius:14px;background:var(--orange-100);display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:14px;" aria-hidden="true">{b.icon}</div>
          <h3 style="font-size:18px;margin-bottom:8px;">{b.title}</h3>
          <p style="font-size:14px;color:var(--ink-500);">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
