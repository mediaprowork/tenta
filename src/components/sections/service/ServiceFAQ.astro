---
interface Faq { q: string; a: string; }
interface Props { items: Faq[]; }
const { items } = Astro.props;
---
<section style="background:var(--bg-warm);">
  <div class="container" style="max-width:820px;">
    <h2 class="section-title">Pertanyaan Umum</h2>
    <p class="section-sub" style="margin-bottom:32px;">Hal yang sering ditanyakan tentang layanan ini.</p>
    <div style="display:flex;flex-direction:column;gap:12px;">
      {items.map((it, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-q" style="cursor:pointer;list-style:none;">
            <span>{it.q}</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </summary>
          <div class="faq-a" style="max-height:none;margin-top:12px;">{it.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>
<style>
  details summary::-webkit-details-marker { display: none; }
  details[open] .faq-toggle { transform: rotate(45deg); background: var(--orange-500); color: white; }
  details:not([open]) .faq-a { display: none; }
</style>
