---
import { getCollection } from 'astro:content';

const cases = await getCollection('caseStudies');
---
<section style="background:var(--bg-warm);">
  <div class="container">
    <h2 class="section-title">Case Study Pilihan</h2>
    <p class="section-sub" style="margin-bottom:40px;">Hasil dari brand yang udah kerja bareng kami.</p>
    <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:20px;">
      {cases.map(c => (
        <a href={`/case-study/${c.id}`} class="card reveal" style="display:flex;flex-direction:column;gap:14px;cursor:pointer;">
          <div style="height:140px;border-radius:12px;background:repeating-linear-gradient(135deg, var(--orange-100), var(--orange-100) 8px, var(--orange-50) 8px, var(--orange-50) 16px);display:flex;align-items:center;justify-content:center;border:1px dashed var(--orange-300);">
            <span style="font-family:monospace;font-size:12px;color:var(--orange-700);">{c.data.brand}</span>
          </div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            {c.data.tags.map(t => <span style="font-size:11px;padding:4px 10px;background:var(--orange-100);color:var(--orange-700);border-radius:999px;font-weight:600;">{t}</span>)}
          </div>
          <h3 style="font-size:19px;">{c.data.brand}</h3>
          <div style="font-size:22px;font-weight:800;color:var(--orange-600);font-family:'Plus Jakarta Sans',sans-serif;">{c.data.metric}</div>
          <p style="font-size:14px;color:var(--ink-500);">{c.data.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>
