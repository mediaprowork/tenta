---
interface Props {
  variant?: 'primary' | 'ghost' | 'wa';
  href?: string;
  type?: 'button' | 'submit';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  target?: string;
  rel?: string;
  id?: string;
  ariaLabel?: string;
}
const {
  variant = 'primary',
  href,
  type = 'button',
  size = 'md',
  class: className = '',
  target,
  rel,
  id,
  ariaLabel,
} = Astro.props;
const variantClass = `btn-${variant}`;
const sizeStyle = size === 'sm' ? 'padding:10px 16px;font-size:14px;' : size === 'lg' ? 'padding:16px 28px;font-size:16px;' : '';
const isExternal = href && /^https?:\/\//.test(href);
const safeRel = isExternal ? (rel || 'noopener noreferrer') : rel;
---
{href ? (
  <a href={href} class={`btn ${variantClass} ${className}`} style={sizeStyle} target={target} rel={safeRel} id={id} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button type={type} class={`btn ${variantClass} ${className}`} style={sizeStyle} id={id} aria-label={ariaLabel}>
    <slot />
  </button>
)}
