---
interface Props {
  src: string;
  alt: string;
  width?: number | string;
  height?: number | string;
  class?: string;
  imgClass?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'sync' | 'auto';
  rounded?: string;     // border-radius for skeleton box
  bgStyle?: string;     // extra CSS on wrapper
}

const {
  src,
  alt,
  width,
  height,
  class: className = '',
  imgClass = '',
  loading = 'lazy',
  fetchpriority = 'auto',
  decoding = 'async',
  rounded,
  bgStyle = '',
} = Astro.props;

// Maintain aspect ratio when both width & height given — prevents layout shift
const aspect = (width && height) ? `aspect-ratio:${width}/${height};` : '';
const radius = rounded ? `border-radius:${rounded};` : '';
const wrapStyle = `${aspect}${radius}${bgStyle}`;
---
<span class={`lazy-img-wrap ${className}`} style={wrapStyle}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={imgClass}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
  />
</span>

<script>
  // Mark image as loaded → fade in & hide skeleton shimmer
  function initLazy() {
    const imgs = document.querySelectorAll<HTMLImageElement>('.lazy-img-wrap img:not([data-lazy-init])');
    imgs.forEach(img => {
      img.setAttribute('data-lazy-init', '1');
      const wrap = img.parentElement;
      const markLoaded = () => {
        img.classList.add('loaded');
        wrap?.classList.add('loaded');
      };
      if (img.complete && img.naturalHeight !== 0) {
        markLoaded();
      } else {
        img.addEventListener('load', markLoaded, { once: true });
        img.addEventListener('error', markLoaded, { once: true });
      }
    });
  }
  initLazy();
  // re-init in case more images added dynamically
  document.addEventListener('astro:page-load', initLazy);
</script>
