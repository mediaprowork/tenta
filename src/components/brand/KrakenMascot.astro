---
interface Props {
  size?: number;
  animate?: boolean;
  eyeId?: string;   // when set, adds data attrs for cursor-tracking
  class?: string;
}
const { size = 280, animate = true, eyeId, class: className = '' } = Astro.props;
const animStyle = (kf: string, dur: string) => animate ? `animation:${kf} ${dur} ease-in-out infinite;` : '';
---
<svg viewBox="0 0 320 320" width={size} height={size} class={className} style="overflow:visible;" aria-hidden="true">
  <defs>
    <linearGradient id="bodyGrad" x1="30%" y1="20%" x2="80%" y2="90%">
      <stop offset="0%" stop-color="#FF9447" />
      <stop offset="100%" stop-color="#F26416" />
    </linearGradient>
  </defs>

  <!-- Back tentacles -->
  <g style={`transform-origin:85px 200px;${animStyle('wave1', '3.6s')}`}>
    <path d="M 95 195 Q 55 210 40 250 Q 35 285 65 285 Q 85 280 90 250" fill="url(#bodyGrad)" />
    <circle cx="60" cy="270" r="4" fill="#FFD9B8" opacity="0.6"/>
  </g>
  <g style={`transform-origin:235px 200px;${animStyle('wave2', '4.2s')}`}>
    <path d="M 225 195 Q 265 210 280 250 Q 285 285 255 285 Q 235 280 230 250" fill="url(#bodyGrad)" />
    <circle cx="260" cy="270" r="4" fill="#FFD9B8" opacity="0.6"/>
  </g>

  <!-- Body -->
  <ellipse cx="160" cy="155" rx="100" ry="92" fill="url(#bodyGrad)"/>

  <!-- Front tentacles -->
  <path d="M 120 230 Q 100 270 110 295 Q 130 305 140 285 Q 138 260 130 235" fill="url(#bodyGrad)"/>
  <path d="M 200 230 Q 220 270 210 295 Q 190 305 180 285 Q 182 260 190 235" fill="url(#bodyGrad)"/>
  <path d="M 160 245 Q 145 280 158 305 Q 172 280 160 245" fill="url(#bodyGrad)"/>

  <!-- Cheeks -->
  <ellipse cx="118" cy="170" rx="16" ry="10" fill="#FFB8B8" opacity="0.55"/>
  <ellipse cx="202" cy="170" rx="16" ry="10" fill="#FFB8B8" opacity="0.55"/>

  <!-- Eye whites -->
  <ellipse cx="138" cy="142" rx="18" ry="20" fill="white"/>
  <ellipse cx="182" cy="142" rx="18" ry="20" fill="white"/>

  <!-- Left eye — outer group: blink | inner group: cursor follow -->
  <g style={`transform-origin:138px 144px;${animStyle('blink', '5s')}`}>
    <g data-pupil={eyeId ? `${eyeId}-left` : undefined}>
      <circle cx="140" cy="146" r="9" fill="#0E1B2A"/>
      <circle cx="143" cy="142" r="3" fill="white"/>
    </g>
  </g>

  <!-- Right eye — outer group: blink | inner group: cursor follow -->
  <g style={`transform-origin:182px 144px;${animStyle('blink', '5s')}`}>
    <g data-pupil={eyeId ? `${eyeId}-right` : undefined}>
      <circle cx="184" cy="146" r="9" fill="#0E1B2A"/>
      <circle cx="187" cy="142" r="3" fill="white"/>
    </g>
  </g>

  <!-- Smile -->
  <path d="M 148 182 Q 160 196 172 182" fill="none" stroke="#0E1B2A" stroke-width="3.5" stroke-linecap="round"/>

  <!-- Click cursor accent -->
  <g transform="translate(245, 75) rotate(-12)">
    <path d="M 0 0 L 0 22 L 6 17 L 11 27 L 14 25 L 9 16 L 16 16 Z" fill="#0E1B2A"/>
    <path d="M 0 0 L 0 22 L 6 17 L 11 27 L 14 25 L 9 16 L 16 16 Z" fill="none" stroke="white" stroke-width="1.5"/>
    <line x1="22" y1="-4" x2="28" y2="-10" stroke="#FF7A1A" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="24" y1="6" x2="32" y2="6" stroke="#FF7A1A" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="20" y1="14" x2="26" y2="20" stroke="#FF7A1A" stroke-width="2.5" stroke-linecap="round"/>
  </g>
</svg>
