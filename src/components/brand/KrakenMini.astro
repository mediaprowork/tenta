---
interface Props { size?: number; animate?: boolean; class?: string; }
const { size = 120, animate = true, class: className = '' } = Astro.props;
const animStyle = (kf: string, dur: string) => animate ? `animation:${kf} ${dur} ease-in-out infinite;` : '';
---
<svg viewBox="0 0 200 200" width={size} height={size} class={className} style="overflow:visible;" aria-hidden="true">
  <defs>
    <linearGradient id="miniGrad" x1="30%" y1="20%" x2="80%" y2="90%">
      <stop offset="0%" stop-color="#FF9447" />
      <stop offset="100%" stop-color="#F26416" />
    </linearGradient>
  </defs>
  <g style={`transform-origin:60px 130px;${animStyle('wave1', '3s')}`}>
    <path d="M 70 125 Q 40 140 30 170 Q 30 190 55 188 Q 70 180 75 155" fill="url(#miniGrad)"/>
  </g>
  <g style={`transform-origin:140px 130px;${animStyle('wave2', '3.4s')}`}>
    <path d="M 130 125 Q 160 140 170 170 Q 170 190 145 188 Q 130 180 125 155" fill="url(#miniGrad)"/>
  </g>
  <ellipse cx="100" cy="100" rx="64" ry="58" fill="url(#miniGrad)"/>
  <path d="M 78 152 Q 68 182 82 195 Q 95 182 88 158" fill="url(#miniGrad)"/>
  <path d="M 122 152 Q 132 182 118 195 Q 105 182 112 158" fill="url(#miniGrad)"/>
  <path d="M 100 158 Q 92 188 100 200 Q 108 188 100 158" fill="url(#miniGrad)"/>
  <ellipse cx="74" cy="110" rx="10" ry="6" fill="#FFB8B8" opacity="0.55"/>
  <ellipse cx="126" cy="110" rx="10" ry="6" fill="#FFB8B8" opacity="0.55"/>
  <ellipse cx="86" cy="92" rx="12" ry="13" fill="white"/>
  <ellipse cx="114" cy="92" rx="12" ry="13" fill="white"/>
  <g style={`transform-origin:86px 94px;${animStyle('blink', '5s')}`}>
    <circle cx="88" cy="96" r="6" fill="#0E1B2A"/>
    <circle cx="90" cy="93" r="2" fill="white"/>
  </g>
  <g style={`transform-origin:114px 94px;${animStyle('blink', '5s')}`}>
    <circle cx="116" cy="96" r="6" fill="#0E1B2A"/>
    <circle cx="118" cy="93" r="2" fill="white"/>
  </g>
  <path d="M 92 120 Q 100 130 108 120" fill="none" stroke="#0E1B2A" stroke-width="2.5" stroke-linecap="round"/>
</svg>
